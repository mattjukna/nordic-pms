generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

model Supplier {
  id                 String        @id @default(cuid())
  name               String
  routeGroup         String
  companyCode        String?
  phoneNumber        String?
  country            String?
  addressLine1       String?
  addressLine2       String?
  createdOn          BigInt?       
  contractQuota      Float?
  basePricePerKg     Float?
  fatBonusPerPct     Float?
  proteinBonusPerPct Float?
  isEco              Boolean       @default(false)
  defaultMilkType    String?
  intakes            IntakeEntry
}

model IntakeEntry {
  id             String   @id @default(cuid())
  supplierId     String
  supplier       Supplier @relation(fields: [supplierId], references: [id])
  supplierName   String   
  routeGroup     String
  milkType       String
  quantityKg     Float
  fatPct         Float
  proteinPct     Float
  tempCelsius    Float
  isEcological   Boolean  @default(false)
  note           String?
  timestamp      BigInt
  calculatedCost Float
}

model Product {
  id                  String        @id
  name                String
  details             String?
  defaultPalletWeight Float
  defaultBagWeight    Float
  proteinTargetPct    Float
  yieldFactor         Float
  outputs             OutputEntry
}

model OutputEntry {
  id              String  @id @default(cuid())
  productId       String
  product         Product @relation(fields: [productId], references: [id])
  batchId         String
  packagingString String
  destination     String
  timestamp       BigInt
  pallets         Int?
  bigBags         Int?
  totalWeight     Float?
}

model Buyer {
  id           String          @id @default(cuid())
  name         String
  companyCode  String?
  phoneNumber  String?
  country      String?
  addressLine1 String?
  addressLine2 String?
  createdOn    BigInt?
  contracts    BuyerContract
}

model BuyerContract {
  id             String   @id @default(cuid())
  contractNumber String
  productId      String
  pricePerKg     Float
  agreedAmountKg Float
  startDate      BigInt
  endDate        BigInt
  buyerId        String
  buyer          Buyer    @relation(fields: [buyerId], references: [id])
}

model DispatchEntry {
  id              String  @id @default(cuid())
  date            BigInt
  buyer           String  
  contractNumber  String?
  productId       String
  quantityKg      Float
  batchRefId      String
  packagingString String?
  salesPricePerKg Float
  totalRevenue    Float
  status          String  
}