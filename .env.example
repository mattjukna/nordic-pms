## Example .env (placeholders only)
# Use a single DATABASE_URL in Prisma format. Do NOT commit secrets.

# Example Prisma-style connection string for Azure SQL (replace placeholders):
# DATABASE_URL="sqlserver://<user>:<password>@<your-server-name>.database.windows.net:1433;database=<database-name>;encrypt=true;trustServerCertificate=false"

# Optional: keep legacy env vars for local scripts (placeholders):
# DB_USER=<db-user>
# DB_PASSWORD=<db-password>
# DB_SERVER=<your-server>.database.windows.net
# DB_DATABASE=<database-name>

# Azure AD / MSAL configuration (frontend)
VITE_AAD_CLIENT_ID=
VITE_AAD_TENANT_ID=
VITE_AAD_ALLOWED_DOMAIN=nordicproteins.com
VITE_AAD_API_SCOPE=api://<client-id>/access_as_user

# Debugging helpers
# When true, installs a logout debugger that logs and traces logout calls
# but the Sign out menu item will still perform a real logout.
VITE_AUTH_DEBUG_LOGOUT=false

# Azure AD / MSAL configuration (backend)
AAD_CLIENT_ID=
AAD_TENANT_ID=
AAD_ALLOWED_DOMAIN=nordicproteins.com
# Optional: set to true to skip auth locally
AUTH_DISABLED=false
