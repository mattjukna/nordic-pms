{
  "name": "nordic-production-log",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:client": "vite build",
    "build:server": "prisma generate --schema nordic-backend/prisma/schema.prisma && tsup server.ts --format esm --platform node --target node22 --out-dir dist-server --clean --sourcemap --splitting=false --external vite --external lightningcss && npm run fix:esm",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/server.js",
    "prisma:generate": "prisma generate --schema nordic-backend/prisma/schema.prisma",
    "prisma:push": "prisma db push --schema nordic-backend/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema nordic-backend/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema nordic-backend/prisma/schema.prisma",
    "prisma:seed": "prisma db seed --schema nordic-backend/prisma/schema.prisma",
    "lint": "tsc --noEmit",
    "preview": "vite preview",
    "fix:esm": "node scripts/fix-esm-imports.mjs dist-server"
  },
  "dependencies": {
    "@azure/msal-browser": "2.38.4",
    "@azure/msal-react": "1.5.13",
    "@prisma/client": "6.19.2",
    "clsx": "2.1.0",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "jose": "5.10.0",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "0.263.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "9.0.1",
    "recharts": "2.12.0",
    "tailwind-merge": "2.2.1",
    "zustand": "4.5.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "cross-env": "^7.0.3",
    "prisma": "6.19.2",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^7.3.1"
  },
  "prisma": {
    "seed": "tsx nordic-backend/prisma/seed.ts"
  }
}
