generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
}

enum DispatchStatus {
  planned
  confirmed
  completed
}

enum OutputDestination {
  Warehouse
  PienoZvaigzde
  Export
}

model Supplier {
  id                 String       @id @default(cuid())
  name               String
  routeGroup         String
  contractQuota      Float?
  companyCode        String?
  phoneNumber        String?
  country            String?
  addressLine1       String?
  addressLine2       String?
  createdOn          DateTime?
  basePricePerKg     Float?
  fatBonusPerPct     Float?
  proteinBonusPerPct Float?
  isEco              Boolean      @default(false)
  defaultMilkType    String?

  intakes            IntakeEntry[]
}

model MilkType {
  name String @id
}

model Product {
  id                  String        @id
  name                String
  details             String?
  defaultPalletWeight Float
  defaultBagWeight    Float
  proteinTargetPct    Float
  yieldFactor         Float

  outputs             OutputEntry[]
  contracts           BuyerContract[]
  dispatches          DispatchEntry[]
}

model Buyer {
  id           String         @id @default(cuid())
  name         String
  companyCode  String?
  phoneNumber  String?
  country      String?
  addressLine1 String?
  addressLine2 String?
  createdOn    DateTime?

  contracts    BuyerContract[]
  dispatches   DispatchEntry[]
}

model BuyerContract {
  id             String   @id @default(cuid())
  contractNumber String
  pricePerKg     Float
  agreedAmountKg Float?
  startDate      DateTime
  endDate        DateTime

  buyerId        String
  buyer          Buyer    @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  productId      String
  product        Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@unique([buyerId, contractNumber])
  @@index([productId])
}

model IntakeEntry {
  id                String      @id @default(cuid())
  supplierId        String
  supplier          Supplier    @relation(fields: [supplierId], references: [id], onDelete: Restrict)

  supplierName      String
  routeGroup        String
  milkType          String
  quantityKg        Float
  ph                Float
  fatPct            Float
  proteinPct        Float
  tempCelsius       Float
  isEcological      Boolean     @default(false)
  note              String?
  timestamp         DateTime
  calculatedCost    Float
  isTempAlertDismissed Boolean  @default(false)
  isDiscarded       Boolean     @default(false)

  tags              IntakeTag[]

  @@index([supplierId])
  @@index([timestamp])
}

model IntakeTag {
  id           String     @id @default(cuid())
  intakeEntryId String
  intakeEntry  IntakeEntry @relation(fields: [intakeEntryId], references: [id], onDelete: Cascade)
  tag          String

  @@unique([intakeEntryId, tag])
}

model OutputEntry {
  id              String           @id @default(cuid())
  productId       String
  product         Product          @relation(fields: [productId], references: [id], onDelete: Restrict)

  batchId         String
  packagingString String
  destination     OutputDestination
  timestamp       DateTime

  pallets         Float
  bigBags         Float
  tanks           Float
  totalWeight     Float

  @@index([productId])
  @@index([timestamp])
}

model DispatchEntry {
  id              String         @id @default(cuid())
  date            DateTime

  buyerId         String?
  buyer           Buyer?         @relation(fields: [buyerId], references: [id], onDelete: SetNull)

  buyerName       String
  contractNumber  String?

  productId       String
  product         Product        @relation(fields: [productId], references: [id], onDelete: Restrict)

  quantityKg      Float
  orderedQuantityKg Float?
  batchRefId      String?
  packagingString String?

  pallets         Float?
  bigBags         Float?
  tanks           Float?
  totalWeight     Float?

  salesPricePerKg Float
  totalRevenue    Float
  status          DispatchStatus @default(planned)

  shipments       DispatchShipment[]

  @@index([date])
  @@index([status])
  @@index([productId])
}

model DispatchShipment {
  id              String        @id @default(cuid())
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  date            DateTime
  quantityKg      Float
  batchId         String?
  note            String?
  packagingString String?

  pallets         Float?
  bigBags         Float?
  tanks           Float?
  totalWeight     Float?
}
